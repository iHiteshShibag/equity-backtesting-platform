# =========================================================
# Frontend .dockerignore
# Keeps the Vite/React build context small — dependencies are
# installed fresh inside the image, never copied from the host.
# =========================================================

# Dependencies — installed inside the image via package-lock.json
node_modules/

# Local build outputs
dist/
build/
.vite/

# Environment & secrets — image gets its config via docker-compose env vars
.env
.env.local
.env.*.local
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Version control
.git/
.gitignore

# IDE / editors
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Docs / misc (not needed at runtime)
README.md
*.md
