# =========================================================
# Root .env.example — Global / Docker Compose level variables
# Copy to ".env" in the project root and adjust values locally.
# This file documents shared values used across services
# (Postgres, ports, CORS). Never commit the real ".env".
# =========================================================

# ---------------------------------------------------------
# PostgreSQL (used by the "db" service in docker-compose.yml)
# ---------------------------------------------------------
POSTGRES_DB=backtesting_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# ---------------------------------------------------------
# Service ports (host-side mapping — safe to change if a
# port is already taken on your machine, Ubuntu or Windows)
# ---------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ---------------------------------------------------------
# Production only (docker-compose.prod.yml) -- ignored by the
# dev docker-compose.yml. See README's "Production deployment"
# section for the full `docker-compose -f ... -f docker-compose.prod.yml`
# command.
# ---------------------------------------------------------
# Host port nginx (the `frontend` service) publishes; 80/443 for a real
# domain, anything else fine for testing the prod build locally.
HTTP_PORT=80
# Gunicorn worker count for the `backend` service. (2 x CPU cores) + 1 is
# the usual starting point.
GUNICORN_WORKERS=4

# ---------------------------------------------------------
# Cross-service networking
# ---------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------
# General environment
# ---------------------------------------------------------
ENVIRONMENT=development

# ---------------------------------------------------------
# Auth (used by the "backend" and "seed-admin" services).
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------
SECRET_KEY=replace_with_a_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# ---------------------------------------------------------
# Observability (optional). Leave blank to disable Sentry —
# the backend and frontend both no-op without a DSN, and
# structured JSON logging to stdout always runs regardless.
# SENTRY_DSN is for the backend/Celery; SENTRY_DSN_FRONTEND
# is a separate DSN (a different Sentry project) for the
# browser bundle, since browser and server errors are best
# kept in separate Sentry projects.
# ---------------------------------------------------------
SENTRY_DSN=
SENTRY_DSN_FRONTEND=
