# =========================================================
# Backend .env.example — FastAPI service configuration
# Copy to "backend/.env" and fill in real values locally.
# Never commit the real ".env" — only this template.
# =========================================================

# ---------------------------------------------------------
# Database (consumed by app/config.py -> Settings.DATABASE_URL)
# ---------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/backtesting_db

# ---------------------------------------------------------
# CORS (consumed by app/config.py -> Settings.CORS_ORIGINS)
# ---------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------
# Auth (consumed by app/core/config.py). Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------
SECRET_KEY=replace_with_a_long_random_value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap admin account created by `python scripts/seed_admin.py`
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

ENVIRONMENT=development
DEBUG=true
